<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width,initial-scale=1.0"/>
<title>2026 World Cup — Group Stage</title>
<link href="https://fonts.googleapis.com/css2?family=Barlow+Condensed:wght@500;600;700;800;900&family=Barlow:wght@400;500&display=swap" rel="stylesheet">
<style>
*{box-sizing:border-box;margin:0;padding:0}
:root{--red:#B22234;--navy:#3C3B6E;--gold:#f0c040;--accent:#4fc3f7;--green:#27ae60;--muted:#8899aa;--bg:#0e0e1c;--panel:#111122;--border:rgba(255,255,255,.1)}
html,body{background:var(--bg);color:#fff;font-family:'Barlow Condensed',sans-serif;min-height:100vh}

/* NAV */
.nav{background:linear-gradient(90deg,var(--navy),#1a1a3e);border-bottom:3px solid var(--red);padding:0}
.nav-inner{display:flex;align-items:center;gap:0;max-width:100%}
.nav-brand{display:flex;align-items:center;gap:8px;padding:9px 16px;border-right:1px solid var(--border)}
.flag{width:28px;height:19px;position:relative;border-radius:2px;overflow:hidden;border:1px solid rgba(255,255,255,.3);flex-shrink:0}
.fr{height:6.3px;width:100%}.fc{position:absolute;top:0;left:0;width:38%;height:66%;background:var(--navy)}
.brand-title{font-size:15px;font-weight:900;letter-spacing:1.5px;text-transform:uppercase;white-space:nowrap}.brand-title span{color:var(--red)}
.nav-tabs{display:flex;gap:0;flex:1;overflow-x:auto}
.nav-tab{padding:12px 18px;font-size:13px;font-weight:800;letter-spacing:.5px;text-transform:uppercase;color:var(--muted);text-decoration:none;white-space:nowrap;border-bottom:3px solid transparent;margin-bottom:-3px;transition:.12s}
.nav-tab:hover{color:#fff;background:rgba(255,255,255,.05)}
.nav-tab.active{color:var(--accent);border-bottom-color:var(--accent)}

/* MAIN */
.page{padding:16px}
.page-title{font-size:22px;font-weight:900;letter-spacing:2px;text-transform:uppercase;margin-bottom:4px}
.page-sub{font-size:11px;color:var(--muted);letter-spacing:.5px;margin-bottom:16px}
.groups-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(380px,1fr));gap:14px}

/* GROUP CARD */
.group-card{background:var(--panel);border-radius:8px;overflow:hidden;border:1px solid var(--border)}
.group-hdr{background:linear-gradient(90deg,var(--navy),#1a1a3e);padding:8px 12px;display:flex;align-items:center;justify-content:space-between}
.group-name{font-size:15px;font-weight:900;letter-spacing:1px;text-transform:uppercase}
.group-conf{font-size:10px;color:var(--muted);font-weight:600;letter-spacing:.5px}

/* STANDINGS TABLE */
.standings{width:100%;border-collapse:collapse}
.standings th{font-size:9px;font-weight:800;letter-spacing:1px;text-transform:uppercase;color:var(--muted);padding:5px 8px;text-align:center;border-bottom:1px solid var(--border)}
.standings th:first-child{text-align:left}
.standings td{font-size:12px;font-weight:700;padding:7px 8px;text-align:center;border-bottom:1px solid rgba(255,255,255,.04)}
.standings td:first-child{text-align:left}
.standings tr:last-child td{border-bottom:none}
.standings tr:hover td{background:rgba(255,255,255,.04)}
.rank-badge{display:inline-flex;align-items:center;justify-content:center;width:18px;height:18px;border-radius:50%;font-size:10px;font-weight:900;margin-right:6px;flex-shrink:0}
.rank-1{background:var(--gold);color:#111}
.rank-2{background:#aaa;color:#111}
.rank-3{background:rgba(79,195,247,.3);color:var(--accent);border:1px solid var(--accent)}
.rank-4{background:rgba(255,255,255,.08);color:var(--muted)}
.team-cell{display:flex;align-items:center;gap:4px;white-space:nowrap}
.team-flag{font-size:16px;line-height:1}
.team-name{font-size:12px;font-weight:700}
.pts{font-size:14px;font-weight:900;color:var(--gold)}
.qual-stripe{width:3px;position:absolute;left:0;top:0;bottom:0}
.standings tr{position:relative}
.q-auto{box-shadow:inset 3px 0 0 var(--gold)}
.q-maybe{box-shadow:inset 3px 0 0 var(--accent)}
.gd-pos{color:#4fc3f7}.gd-neg{color:#ef5350}.gd-zero{color:var(--muted)}

/* SCORE ENTRY */
.matches-section{padding:8px 12px 10px;border-top:1px solid var(--border)}
.matches-title{font-size:9px;font-weight:800;letter-spacing:1.5px;text-transform:uppercase;color:var(--muted);margin-bottom:6px}
.match-row{display:flex;align-items:center;gap:6px;margin-bottom:4px;font-size:11px}
.match-teams{display:flex;align-items:center;gap:4px;flex:1;min-width:0}
.match-team{flex:1;text-align:right;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;font-weight:700;font-size:11px}
.match-team.away{text-align:left}
.match-sep{font-size:10px;color:var(--muted);flex-shrink:0}
.score-box{display:flex;align-items:center;gap:3px;flex-shrink:0}
.score-input{width:30px;height:26px;text-align:center;background:rgba(255,255,255,.08);border:1px solid var(--border);border-radius:4px;color:#fff;font-family:'Barlow Condensed',sans-serif;font-size:13px;font-weight:900;outline:none}
.score-input:focus{border-color:var(--accent);background:rgba(255,255,255,.12)}
.score-dash{font-size:12px;color:var(--muted);font-weight:900}

/* LEGEND */
.legend{display:flex;align-items:center;gap:16px;padding:12px 16px;background:rgba(255,255,255,.03);border-radius:6px;margin-bottom:14px;flex-wrap:wrap}
.legend-item{display:flex;align-items:center;gap:6px;font-size:11px;color:var(--muted)}
.legend-dot{width:10px;height:10px;border-radius:2px;flex-shrink:0}

/* 3RD PLACE TRACKER */
.third-section{background:var(--panel);border-radius:8px;border:1px solid var(--border);margin-top:16px;overflow:hidden}
.third-hdr{background:linear-gradient(90deg,rgba(79,195,247,.15),rgba(79,195,247,.05));padding:10px 14px;border-bottom:1px solid var(--border);display:flex;align-items:center;justify-content:space-between}
.third-title{font-size:14px;font-weight:900;letter-spacing:1px;text-transform:uppercase;color:var(--accent)}
.third-sub{font-size:10px;color:var(--muted);font-weight:600}
.third-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(160px,1fr));gap:6px;padding:12px}
.third-row{display:flex;align-items:center;gap:8px;padding:6px 8px;border-radius:5px;border:1px solid var(--border);background:rgba(255,255,255,.03)}
.third-rank{font-size:16px;font-weight:900;color:var(--gold);min-width:20px;text-align:center}
.third-info{min-width:0}
.third-team{font-size:12px;font-weight:700;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
.third-pts{font-size:10px;color:var(--muted)}
.third-advancing{border-color:var(--accent);background:rgba(79,195,247,.08)}
.third-advancing .third-rank{color:var(--accent)}

::-webkit-scrollbar{width:3px;height:3px}::-webkit-scrollbar-thumb{background:rgba(255,255,255,.15);border-radius:2px}
</style>
</head>
<body>

<div class="nav">
  <div class="nav-inner">
    <div class="nav-brand">
      <div class="flag"><div class="fr" style="background:#B22234"></div><div class="fr" style="background:#fff"></div><div class="fr" style="background:#B22234"></div><div class="fc"></div></div>
      <div class="brand-title"><span>2026</span> FIFA World Cup</div>
    </div>
    <div class="nav-tabs">
      <a class="nav-tab" href="index.html">⚽ Tactical Board</a>
      <a class="nav-tab active" href="groups.html">📊 Group Stage</a>
      <a class="nav-tab" href="bracket.html">🏆 Bracket</a>
    </div>
  </div>
</div>

<div class="page">
  <div class="page-title">Group Stage Standings</div>
  <div class="page-sub">Enter match scores below each group — standings update automatically · Top 2 advance · Best 8 third-place teams also advance</div>

  <div class="legend">
    <div class="legend-item"><div class="legend-dot" style="background:var(--gold)"></div>Qualified (1st/2nd)</div>
    <div class="legend-item"><div class="legend-dot" style="background:var(--accent);opacity:.5"></div>Possible 3rd place qualifier</div>
    <div class="legend-item"><div class="legend-dot" style="background:rgba(255,255,255,.15)"></div>Eliminated</div>
  </div>

  <div class="groups-grid" id="groups-grid"></div>

  <div class="third-section">
    <div class="third-hdr">
      <div class="third-title">Best 3rd Place Rankings</div>
      <div class="third-sub">Top 8 advance to Round of 32 · ranked by Pts → GD → GF → Fair Play</div>
    </div>
    <div class="third-grid" id="third-grid"></div>
  </div>
</div>

<script>
// ── GROUPS DATA ──
const GROUPS = {
  A:{conf:"CONCACAF/AFC/UEFA",teams:["Mexico","South Africa","South Korea","Czechia"],matches:[[0,1],[2,3],[0,2],[1,3],[0,3],[1,2]]},
  B:{conf:"CONCACAF/UEFA/AFC",teams:["Canada","Bosnia & Herz.","Qatar","Switzerland"],matches:[[0,1],[2,3],[0,2],[1,3],[0,3],[1,2]]},
  C:{conf:"CONMEBOL/CAF/UEFA/CONCACAF",teams:["Brazil","Morocco","Scotland","Haiti"],matches:[[0,1],[2,3],[0,2],[1,3],[0,3],[1,2]]},
  D:{conf:"CONCACAF/CONMEBOL/AFC/UEFA",teams:["USA","Paraguay","Australia","Türkiye"],matches:[[0,1],[2,3],[0,2],[1,3],[0,3],[1,2]]},
  E:{conf:"UEFA/CONCACAF/CAF/CONMEBOL",teams:["Germany","Curaçao","Ivory Coast","Ecuador"],matches:[[0,1],[2,3],[0,2],[1,3],[0,3],[1,2]]},
  F:{conf:"UEFA/AFC/UEFA",teams:["Netherlands","Japan","Sweden","Tunisia"],matches:[[0,1],[2,3],[0,2],[1,3],[0,3],[1,2]]},
  G:{conf:"UEFA/CAF/AFC/OFC",teams:["Belgium","Egypt","Iran","New Zealand"],matches:[[0,1],[2,3],[0,2],[1,3],[0,3],[1,2]]},
  H:{conf:"UEFA/CONMEBOL/AFC/CAF",teams:["Spain","Uruguay","Saudi Arabia","Cape Verde"],matches:[[0,1],[2,3],[0,2],[1,3],[0,3],[1,2]]},
  I:{conf:"UEFA/CAF/UEFA/AFC",teams:["France","Senegal","Norway","Iraq"],matches:[[0,1],[2,3],[0,2],[1,3],[0,3],[1,2]]},
  J:{conf:"CONMEBOL/CAF/UEFA/AFC",teams:["Argentina","Algeria","Austria","Jordan"],matches:[[0,1],[2,3],[0,2],[1,3],[0,3],[1,2]]},
  K:{conf:"UEFA/CONMEBOL/AFC/CAF",teams:["Portugal","Colombia","Uzbekistan","DR Congo"],matches:[[0,1],[2,3],[0,2],[1,3],[0,3],[1,2]]},
  L:{conf:"UEFA/UEFA/CONCACAF/CAF",teams:["England","Croatia","Ghana","Panama"],matches:[[0,1],[2,3],[0,2],[1,3],[0,3],[1,2]]},
};

const FLAGS = {
  "Mexico":"🇲🇽","South Africa":"🇿🇦","South Korea":"🇰🇷","Czechia":"🇨🇿",
  "Canada":"🇨🇦","Bosnia & Herz.":"🇧🇦","Qatar":"🇶🇦","Switzerland":"🇨🇭",
  "Brazil":"🇧🇷","Morocco":"🇲🇦","Scotland":"🏴󠁧󠁢󠁳󠁣󠁴󠁿","Haiti":"🇭🇹",
  "USA":"🇺🇸","Paraguay":"🇵🇾","Australia":"🇦🇺","Türkiye":"🇹🇷",
  "Germany":"🇩🇪","Curaçao":"🇨🇼","Ivory Coast":"🇨🇮","Ecuador":"🇪🇨",
  "Netherlands":"🇳🇱","Japan":"🇯🇵","Sweden":"🇸🇪","Tunisia":"🇹🇳",
  "Belgium":"🇧🇪","Egypt":"🇪🇬","Iran":"🇮🇷","New Zealand":"🇳🇿",
  "Spain":"🇪🇸","Uruguay":"🇺🇾","Saudi Arabia":"🇸🇦","Cape Verde":"🇨🇻",
  "France":"🇫🇷","Senegal":"🇸🇳","Norway":"🇳🇴","Iraq":"🇮🇶",
  "Argentina":"🇦🇷","Algeria":"🇩🇿","Austria":"🇦🇹","Jordan":"🇯🇴",
  "Portugal":"🇵🇹","Colombia":"🇨🇴","Uzbekistan":"🇺🇿","DR Congo":"🇨🇩",
  "England":"🏴󠁧󠁢󠁥󠁮󠁧󠁿","Croatia":"🇭🇷","Ghana":"🇬🇭","Panama":"🇵🇦",
};

const MATCH_NAMES = {
  A:[["Mexico","South Africa"],["South Korea","Czechia"],["Mexico","South Korea"],["South Africa","Czechia"],["Mexico","Czechia"],["South Africa","South Korea"]],
  B:[["Canada","Bosnia & Herz."],["Qatar","Switzerland"],["Canada","Qatar"],["Bosnia & Herz.","Switzerland"],["Canada","Switzerland"],["Bosnia & Herz.","Qatar"]],
  C:[["Brazil","Morocco"],["Scotland","Haiti"],["Brazil","Scotland"],["Morocco","Haiti"],["Brazil","Haiti"],["Morocco","Scotland"]],
  D:[["USA","Paraguay"],["Australia","Türkiye"],["USA","Australia"],["Paraguay","Türkiye"],["USA","Türkiye"],["Paraguay","Australia"]],
  E:[["Germany","Curaçao"],["Ivory Coast","Ecuador"],["Germany","Ivory Coast"],["Curaçao","Ecuador"],["Germany","Ecuador"],["Curaçao","Ivory Coast"]],
  F:[["Netherlands","Japan"],["Sweden","Tunisia"],["Netherlands","Sweden"],["Japan","Tunisia"],["Netherlands","Tunisia"],["Japan","Sweden"]],
  G:[["Belgium","Egypt"],["Iran","New Zealand"],["Belgium","Iran"],["Egypt","New Zealand"],["Belgium","New Zealand"],["Egypt","Iran"]],
  H:[["Spain","Cape Verde"],["Saudi Arabia","Uruguay"],["Spain","Saudi Arabia"],["Cape Verde","Uruguay"],["Spain","Uruguay"],["Cape Verde","Saudi Arabia"]],
  I:[["France","Senegal"],["Iraq","Norway"],["France","Iraq"],["Senegal","Norway"],["France","Norway"],["Senegal","Iraq"]],
  J:[["Argentina","Algeria"],["Austria","Jordan"],["Argentina","Austria"],["Algeria","Jordan"],["Argentina","Jordan"],["Algeria","Austria"]],
  K:[["Portugal","DR Congo"],["Uzbekistan","Colombia"],["Portugal","Uzbekistan"],["DR Congo","Colombia"],["Portugal","Colombia"],["DR Congo","Uzbekistan"]],
  L:[["England","Croatia"],["Ghana","Panama"],["England","Ghana"],["Croatia","Panama"],["England","Panama"],["Croatia","Ghana"]],
};

// State: scores[group][matchIdx] = {h, a}
let scores = {};
// Load from localStorage
try { scores = JSON.parse(localStorage.getItem('wc26_group_scores')||'{}'); } catch(e){}

function saveScores(){ localStorage.setItem('wc26_group_scores', JSON.stringify(scores)); }

function getStandings(grp) {
  const g = GROUPS[grp];
  const teams = g.teams.map(t=>({ name:t, p:0, w:0, d:0, l:0, gf:0, ga:0, gd:0, pts:0 }));
  const ms = MATCH_NAMES[grp];
  const sc = scores[grp]||{};

  ms.forEach((match, mi) => {
    const s = sc[mi];
    if (!s || s.h==='' || s.a==='' || s.h===undefined || s.a===undefined) return;
    const h = parseInt(s.h), a = parseInt(s.a);
    if (isNaN(h)||isNaN(a)) return;
    const [hn, an] = match;
    const hi = g.teams.indexOf(hn), ai = g.teams.indexOf(an);
    teams[hi].p++; teams[ai].p++;
    teams[hi].gf+=h; teams[hi].ga+=a; teams[hi].gd+=h-a;
    teams[ai].gf+=a; teams[ai].ga+=h; teams[ai].gd+=a-h;
    if(h>a){ teams[hi].w++; teams[hi].pts+=3; teams[ai].l++; }
    else if(a>h){ teams[ai].w++; teams[ai].pts+=3; teams[hi].l++; }
    else { teams[hi].d++; teams[ai].d++; teams[hi].pts++; teams[ai].pts++; }
  });

  teams.sort((a,b)=>b.pts-a.pts||b.gd-a.gd||b.gf-a.gf||a.name.localeCompare(b.name));
  return teams;
}

function renderAll() {
  renderGroups();
  renderThirdPlace();
  // Push to bracket page via localStorage
  const allStandings = {};
  Object.keys(GROUPS).forEach(g=>{ allStandings[g]=getStandings(g); });
  localStorage.setItem('wc26_standings', JSON.stringify(allStandings));
}

function renderGroups() {
  const grid = document.getElementById('groups-grid');
  grid.innerHTML = '';
  Object.keys(GROUPS).forEach(grp => {
    const g = GROUPS[grp];
    const standings = getStandings(grp);
    const ms = MATCH_NAMES[grp];
    const sc = scores[grp]||{};

    const card = document.createElement('div'); card.className='group-card';

    // Header
    const hdr = document.createElement('div'); hdr.className='group-hdr';
    hdr.innerHTML=`<div class="group-name">Group ${grp}</div><div class="group-conf">${g.conf}</div>`;
    card.appendChild(hdr);

    // Standings table
    const tbl = document.createElement('table'); tbl.className='standings';
    tbl.innerHTML=`<thead><tr><th colspan="2">Team</th><th title="Played">P</th><th title="Won">W</th><th title="Drawn">D</th><th title="Lost">L</th><th title="Goals For">GF</th><th title="Goals Against">GA</th><th title="Goal Difference">GD</th><th title="Points">Pts</th></tr></thead>`;
    const tbody = document.createElement('tbody');
    standings.forEach((t,i) => {
      const tr = document.createElement('tr');
      if(i<2) tr.className='q-auto';
      else if(i===2) tr.className='q-maybe';
      const gdClass = t.gd>0?'gd-pos':t.gd<0?'gd-neg':'gd-zero';
      const rankCls = ['rank-1','rank-2','rank-3','rank-4'][i];
      tr.innerHTML=`
        <td><span class="rank-badge ${rankCls}">${i+1}</span></td>
        <td><div class="team-cell"><span class="team-flag">${FLAGS[t.name]||'🏳'}</span><span class="team-name">${t.name}</span></div></td>
        <td>${t.p}</td><td>${t.w}</td><td>${t.d}</td><td>${t.l}</td>
        <td>${t.gf}</td><td>${t.ga}</td>
        <td class="${gdClass}">${t.gd>0?'+'+t.gd:t.gd}</td>
        <td class="pts">${t.pts}</td>`;
      tbody.appendChild(tr);
    });
    tbl.appendChild(tbody);
    card.appendChild(tbl);

    // Matches section
    const msec = document.createElement('div'); msec.className='matches-section';
    msec.innerHTML='<div class="matches-title">Match Scores</div>';

    ms.forEach((match, mi) => {
      const [hn, an] = match;
      const s = (sc[mi])||{h:'',a:''};
      const row = document.createElement('div'); row.className='match-row';
      row.innerHTML=`
        <div class="match-teams">
          <div class="match-team">${FLAGS[hn]||''} ${hn}</div>
          <div class="score-box">
            <input class="score-input" type="number" min="0" max="99" value="${s.h!=null?s.h:''}" placeholder="-" data-grp="${grp}" data-mi="${mi}" data-side="h">
            <div class="score-dash">–</div>
            <input class="score-input" type="number" min="0" max="99" value="${s.a!=null?s.a:''}" placeholder="-" data-grp="${grp}" data-mi="${mi}" data-side="a">
          </div>
          <div class="match-team away">${FLAGS[an]||''} ${an}</div>
        </div>`;
      msec.appendChild(row);
    });
    card.appendChild(msec);
    grid.appendChild(card);
  });

  // Bind inputs
  document.querySelectorAll('.score-input').forEach(inp => {
    inp.addEventListener('input', function() {
      const g=this.dataset.grp, mi=this.dataset.mi, side=this.dataset.side;
      if(!scores[g]) scores[g]={};
      if(!scores[g][mi]) scores[g][mi]={h:'',a:''};
      scores[g][mi][side] = this.value;
      saveScores();
      renderAll();
    });
  });
}

function renderThirdPlace() {
  const thirds = [];
  Object.keys(GROUPS).forEach(grp=>{
    const st = getStandings(grp);
    if(st.length>=3){
      thirds.push({ ...st[2], group:grp });
    }
  });
  thirds.sort((a,b)=>b.pts-a.pts||b.gd-a.gd||b.gf-a.gf||a.name.localeCompare(b.name));

  const grid = document.getElementById('third-grid');
  grid.innerHTML='';
  thirds.forEach((t,i)=>{
    const adv = i<8;
    const div = document.createElement('div');
    div.className='third-row'+(adv?' third-advancing':'');
    const gdClass = t.gd>0?'gd-pos':t.gd<0?'gd-neg':'gd-zero';
    div.innerHTML=`
      <div class="third-rank">${i+1}</div>
      <div class="third-info">
        <div class="third-team">${FLAGS[t.name]||''} ${t.name} <small style="color:var(--muted);font-size:9px">(Grp ${t.group})</small></div>
        <div class="third-pts">Pts: <strong style="color:${adv?'var(--accent)':'var(--muted)'}">${t.pts}</strong> · GD: <span class="${gdClass}">${t.gd>0?'+'+t.gd:t.gd}</span> · GF: ${t.gf} ${adv?'<span style="color:var(--accent);font-size:9px">✓ ADV</span>':''}</div>
      </div>`;
    grid.appendChild(div);
  });
  if(!thirds.length){
    grid.innerHTML='<div style="padding:14px;color:var(--muted);font-size:12px;grid-column:1/-1">Enter match scores above to see third-place rankings</div>';
  }
}

renderAll();
</script>
</body>
</html>
